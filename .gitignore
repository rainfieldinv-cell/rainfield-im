# 가상환경 폴더 (용량이 크고 개인 환경마다 다르므로 제외)
venv/

# 접근 코드 등 민감한 정보가 담긴 파일 (절대 공유 금지)
.streamlit/secrets.toml
.env

# Python 캐시 파일 (자동 생성되는 불필요한 파일)
__pycache__/
*.pyc
*.pyo

# 운영체제 자동 생성 파일
.DS_Store
Thumbs.db

# 임시 파일
*.tmp
*.log

# 생성된 PPT 출력물 (자동 생성되므로 git에 불필요)
output/

# 임시 작업 폴더
temp/

# 레이아웃 분석 결과 JSON (자동 생성 파일 — 필요 시 재생성 가능)
templates/layout_data.json

# 단, 레이아웃 템플릿 원본은 git에 포함 (아래 줄로 예외 처리)
!templates/레이아웃.pptx

# 기밀 IM 문서 (PDF) — 사용자가 직접 업로드하므로 repo에 불필요
*.pdf

# 생성된 제안서 PPTX (루트 폴더) — 앱이 만들어주므로 repo에 불필요
/[Rainfield]*.pptx
/[신영증권]*.pptx
/[*]*.pptx

# 개발용 테스트 스크립트
_test_*.py
debug.log

# 메모 탭 저장 파일 (런타임 데이터 — repo에 불필요)
memos.json
